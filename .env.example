# Kopiraj ovu datoteku u .env.local i popuni stvarnim vrijednostima.
# .env.local se NE commita (vidi .gitignore) — svaki developer ima svoju kopiju.

# --- Supabase (dolazi u Fazi 3 — baza podataka) ---
# Javni URL Supabase projekta. Sigurno za frontend (public).
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public ključ. Sigurno za frontend — ograničen Row Level Security pravilima u bazi.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role ključ. NIKAD ne izlagati na frontendu — koristi se samo u
# server-side kodu (npr. admin operacije, Faza 5). Puni pristup bazi mimo RLS-a.
SUPABASE_SERVICE_ROLE_KEY=

# --- Aplikacija ---
# Bazni URL aplikacije, koristi se za SEO metadata (canonical URL, Open Graph).
# Lokalno: http://localhost:3000, produkcija: postavlja se u Vercel Environment Variables.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
