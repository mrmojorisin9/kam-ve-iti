# Kopiraj ovu datoteku u .env.local i popuni stvarnim vrijednostima.
# .env.local se NE commita (vidi .gitignore) — svaki developer ima svoju kopiju.

# --- Supabase ---
# Project Settings -> API Keys u Supabase dashboardu.
#
# Napomena o nazivima: Supabase je 2025. uveo nove "publishable"/"secret"
# ključeve koji zamjenjuju stare "anon"/"service_role". Na novom projektu
# vjerojatno vidiš nove nazive — u tom slučaju upiši ih ovdje. Ako tvoj
# dashboard i dalje prikazuje "anon key" / "service_role key" (legacy tab),
# slobodno upiši te vrijednosti — isto polje, isti kod, radi identično.

# Javni URL Supabase projekta. Sigurno za frontend (public).
NEXT_PUBLIC_SUPABASE_URL=

# Publishable / anon ključ. Sigurno za frontend — pristup ograničen Row
# Level Security pravilima u bazi (vidi supabase/migrations/0001_init_schema.sql).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret / service_role ključ. NIKAD ne izlagati na frontendu (bez
# NEXT_PUBLIC_ prefiksa iz razloga) — koristi se samo u server-side kodu
# (npr. CSV import, admin operacije mimo RLS-a — dolazi u Fazi 5).
SUPABASE_SECRET_KEY=

# --- Aplikacija ---
# Bazni URL aplikacije, koristi se za SEO metadata (canonical URL, Open Graph).
# Lokalno: http://localhost:3000, produkcija: postavlja se u Vercel Environment Variables.
NEXT_PUBLIC_SITE_URL=http://localhost:3000